<div class="post-card">
  <div class="post-top">
    <a class="user-mini" href="/profile/<%= post.username %>">
      <img src="<%= post.avatar %>" alt="avatar">
      <div>
        <strong><%= post.name %></strong>
        <span>@<%= post.username %> · <%= new Date(post.created_at).toLocaleString() %></span>
      </div>
    </a>
    <% if (currentUser && currentUser.id === post.user_id) { %>
      <form action="/posts/<%= post.id %>/delete" method="POST" onsubmit="return confirm('Delete this post?')">
        <button class="icon-delete">Delete</button>
      </form>
    <% } %>
  </div>

  <p class="post-content"><%= post.content %></p>

  <% if (post.media_url && post.media_type === 'image') { %>
    <img class="post-media" src="<%= post.media_url %>" alt="post image">
  <% } %>
  <% if (post.media_url && post.media_type === 'video') { %>
    <video class="post-media" src="<%= post.media_url %>" controls></video>
  <% } %>

  <% if (post.tagList && post.tagList.length) { %>
    <div class="tag-row">
      <% post.tagList.forEach(tag => { %>
        <a href="/feed?tag=<%= tag %>">#<%= tag %></a>
      <% }) %>
    </div>
  <% } %>

  <div class="actions">
    <form action="/posts/<%= post.id %>/like" method="POST">
      <button class="like-btn <%= post.liked_by_me ? 'liked' : '' %>"><%= post.liked_by_me ? '♥ Liked' : '♡ Like' %> <%= post.like_count %></button>
    </form>
    <span>💬 <%= post.comment_count %> Comments</span>
  </div>

  <div class="comments">
    <% post.comments.forEach(comment => { %>
      <div class="comment-item">
        <img src="<%= comment.avatar %>" alt="avatar">
        <div><strong>@<%= comment.username %></strong> <span><%= comment.comment %></span></div>
      </div>
    <% }) %>
  </div>

  <form class="comment-form" action="/posts/<%= post.id %>/comment" method="POST">
    <input type="text" name="comment" placeholder="Write a comment..." required>
    <button>Post</button>
  </form>
</div>
